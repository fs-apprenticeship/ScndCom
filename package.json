{
  "name": "nextjs-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "prisma migrate deploy && prisma generate && next build",
    "check-types": "prisma generate && tsc --project tsconfig.json --pretty --noEmit",
    "db:migrate": "prisma validate && prisma format && prisma-lint && prisma migrate dev && prisma generate && npm run db:reset:test",
    "db:migrate:reset": "node scripts/db-reset.js && npm run db:migrate",
    "db:reset": "node scripts/db-reset.js && prisma generate && prisma db seed && npm run db:reset:test",
    "db:reset:test": "NODE_ENV=test node scripts/db-reset.js",
    "dev": "prisma migrate status && prisma generate && (node scripts/prisma-watch.js & prisma studio --browser none & next dev)",
    "format": "prettier . --write",
    "knip": "knip --production",
    "lint": "eslint",
    "prepare": "husky",
    "start": "next start",
    "test": "NODE_ENV=test prisma migrate status && prisma generate && vitest --coverage"
  },
  "dependencies": {
    "@boundaryml/baml": "^0.222.0",
    "@clerk/nextjs": "^6.39.5",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.8.0",
    "@sentry/nextjs": "^10.40.0",
    "@tailwindcss/postcss": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "lucide-react": "^1.20.0",
    "next": "16.2.6",
    "openai": "^6.27.0",
    "postcss": "^8.5.10",
    "radix-ui": "^1.6.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chax-at/transactional-prisma-testing": "^1.5.0",
    "@commitlint/cli": "^20.4.2",
    "@eslint/markdown": "^7.5.1",
    "@faker-js/faker": "^10.3.0",
    "@quramy/prisma-fabbrica": "^2.3.3",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.40",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/eslint-plugin": "^1.6.9",
    "babel-plugin-react-compiler": "1.0.0",
    "commitlint-plugin-tense": "^1.0.9",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-github-action": "^0.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-yml": "^3.2.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "knip": "^6.12.2",
    "lint-staged": "^16.2.7",
    "madr": "^4.0.0",
    "prettier": "3.8.1",
    "prisma": "^7.8.0",
    "prisma-lint": "^0.13.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vitest-axe": "^0.1.0"
  },
  "overrides": {
    "@quramy/prisma-fabbrica": {
      "@prisma/client": "^7.4.2"
    }
  }
}
